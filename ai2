publish_manager.py
from platforms.instagram import publish_instagram
from platforms.tiktok import publish_tiktok

def publish(post, accounts):

    for acc in accounts:

        if acc.platform == "instagram":

            publish_instagram(
                acc.account_id,
                acc.access_token,
                post["image"],
                post["caption"]
            )

        if acc.platform == "tiktok":

            publish_tiktok(
                post["video"],
                post["caption"],
                acc.access_token
            )
