import requests

def publish_tiktok(video_url, caption, token):

    url = "https://open.tiktokapis.com/v2/post/publish/"

    payload = {
        "video_url": video_url,
        "text": caption
    }

    headers = {
        "Authorization": f"Bearer {token}"
    }

    requests.post(url, json=payload, headers=headers)
