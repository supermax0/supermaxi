from .ai_engine import generate_post
from .image_generator import generate_image

def create_post():

    topic = "فوائد استخدام نظام محاسبة سحابي للشركات الصغيرة"

    caption = generate_post(topic)

    image_prompt = "modern SaaS accounting dashboard marketing image"

    image = generate_image(image_prompt)

    post = {
        "caption": caption,
        "image": image
    }

    return post
