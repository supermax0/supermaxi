# مثال لملف خدمة systemd لـ Finora (Gunicorn)
# المسار: /var/www/finora/supermaxi
# اسم الخدمة: finora
#
# النسخ إلى السيرفر وتعديل القيم:
#   sudo cp deploy/finora.service.example /etc/systemd/system/finora.service
#   sudo nano /etc/systemd/system/finora.service  # استبدل <telegram_bot_token> و <openai_api_key>
#   sudo systemctl daemon-reload
#   sudo systemctl restart finora
#   sudo journalctl -u finora -f

[Unit]
Description=Finora (Gunicorn) — supermaxi
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/finora/supermaxi

# تشغيل Gunicorn
ExecStart=/var/www/finora/supermaxi/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 wsgi:app

# متغيرات البيئة المطلوبة لبوت تيليجرام وردود الذكاء الاصطناعي
Environment="BOT_TOKEN=<telegram_bot_token>"
Environment="OPENAI_API_KEY=<openai_api_key>"

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
