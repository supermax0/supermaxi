[Unit]
Description=Finora SaaS (Gunicorn)
After=network.target

[Service]
User=root
WorkingDirectory=/root/finora-saas
ExecStart=/root/finora-saas/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=3
EnvironmentFile=/root/finora-saas/.env

[Install]
WantedBy=multi-user.target
