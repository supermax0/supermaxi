# انسخ هذا الملف إلى .env وعدّل القيم. لا ترفع ملف .env إلى Git.
# Copy this file to .env and set your values. Do not commit .env to Git.

SECRET_KEY=your-secret-key-change-in-production
# قاعدة البيانات: PostgreSQL (إنتاج) أو SQLite (تطوير)
# DATABASE_URL=postgresql://finora:password@localhost/finora_db
DATABASE_URL=sqlite:///database.db
FLASK_ENV=development

# اختياري — البريد (Optional — Mail)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=465
# MAIL_USERNAME=
# MAIL_PASSWORD=
# CONTACT_EMAIL=

# مفاتيح الذكاء الاصطناعي — AI Agent Builder
# OpenAI (من https://platform.openai.com/api-keys)
# لا تضع المفتاح الحقيقي هنا، هذا فقط مثال
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3

# Gemini (Google AI Studio — https://aistudio.google.com/)
# ملاحظة: تُستخدم حالياً للتخزين في الإعدادات، ويمكن ربطها لاحقاً كمزوّد إضافي.
GEMINI_API_KEY=AIzaSyA2P9TlE6RFjC8hUFJjRq6iB8U7eZa9wxQ
