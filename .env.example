# انسخ هذا الملف إلى .env وعدّل القيم. لا ترفع ملف .env إلى Git.
# Copy this file to .env and set your values. Do not commit .env to Git.

SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///database.db
FLASK_ENV=development

